# Supabase (Project Settings -> API)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# CORS - URL tvog frontenda na Vercelu (npr. https://homeos.vercel.app)
FRONTEND_URL=http://localhost:5173

# Render postavlja PORT automatski, ovo je samo fallback za lokalni rad
PORT=4000

# Resend (Faza 4 - slanje emailova). Napravi nalog na resend.com, uzmi API key.
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Home OS <onboarding@resend.dev>
